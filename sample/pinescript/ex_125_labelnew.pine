//@version=6
strategy("label.new", overlay=true, fill_orders_on_standard_ohlc = true)

// ==================== Original Indicator Logic ====================
var label1 = label.new(bar_index, low, text="Hello, world!", style=label.style_circle)
label.set_x(label1, 0)
label.set_xloc(label1, xloc.bar_time)  // Fixed: removed invalid 'time' argument
label.set_color(label1, color.red)
label.set_size(label1, size.large)

// ==================== Strategy Entry/Exit Logic ====================
longCondition = ta.crossover(ta.sma(close, 14), ta.sma(close, 28))
if (longCondition)
    strategy.entry("Long", strategy.long)

shortCondition = ta.crossunder(ta.sma(close, 14), ta.sma(close, 28))
if (shortCondition)
    strategy.entry("Short", strategy.short)
