// INDICATOR: Chaikin Oscillator Arrows
// Extracted from Pine Script documentation

//@version=6  
strategy("Chaikin Oscillator Arrows", overlay = true)  
fastLengthInput = input.int(3,  minval = 1)  
slowLengthInput = input.int(10, minval = 1)  
osc = ta.ema(ta.accdist, fastLengthInput) - ta.ema(ta.accdist, slowLengthInput)  
plotarrow(osc)

// ==================== Strategy Entry/Exit Logic ====================
longCondition = ta.crossover(ta.sma(close, 14), ta.sma(close, 28))
if (longCondition)
    strategy.entry("Long", strategy.long)

shortCondition = ta.crossunder(ta.sma(close, 14), ta.sma(close, 28))
if (shortCondition)
    strategy.entry("Short", strategy.short)