// INDICATOR: Invalid nested definition demo
// Extracted from Pine Script documentation

//@version=6  
strategy("Invalid nested definition demo", overlay=true)  
  
f(x, y) =>  
    // Defining a separate function inside the body of `f()` is not allowed.  
    g(a, b) => math.sqrt(a * a + b * b)  
    g(x, y) / (x + y)  
  
plot(f(open, close))

// ==================== Strategy Entry/Exit Logic ====================
longCondition = ta.crossover(ta.sma(close, 14), ta.sma(close, 28))
if (longCondition)
    strategy.entry("Long", strategy.long)

shortCondition = ta.crossunder(ta.sma(close, 14), ta.sma(close, 28))
if (shortCondition)
    strategy.entry("Short", strategy.short)