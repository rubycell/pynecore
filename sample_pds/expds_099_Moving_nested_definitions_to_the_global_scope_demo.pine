// INDICATOR: Moving nested definitions to the global scope demo
// Extracted from Pine Script documentation

//@version=6  
strategy("Moving nested definitions to the global scope demo", overlay=true)  
  
// If we move `g()` to the global scope, above `f()`, the `f()` function can use it, and no error occurs.  
g(a, b) => math.sqrt(a * a + b * b)  
  
f(x, y) =>  
    g(x, y) / (x + y)  
  
plot(f(open, close))

// ==================== Strategy Entry/Exit Logic ====================
longCondition = ta.crossover(ta.sma(close, 14), ta.sma(close, 28))
if (longCondition)
    strategy.entry("Long", strategy.long)

shortCondition = ta.crossunder(ta.sma(close, 14), ta.sma(close, 28))
if (shortCondition)
    strategy.entry("Short", strategy.short)